# Required — get from https://aistudio.google.com/apikey
GOOGLE_API_KEY=REDACTED_GOOGLE_API_KEY

# Required — GCP project where APIs are enabled
# Find it: gcloud config get-value project  (or top of GCP Console)
GOOGLE_CLOUD_PROJECT=REDACTED_GCP_PROJECT_ID
GOOGLE_PROJECT_REGION=us-region1
# Deepgram STT — streaming transcription
DEEPGRAM_API_KEY=REDACTED_DEEPGRAM_API_KEY

# ElevenLabs TTS — high-quality voice synthesis
ELEVENLABS_API_KEY=REDACTED_ELEVENLABS_API_KEY

# Gradium TTS/STT — fallback when Gemini Live is recovering
# Voices: English, French, Spanish, German, Portuguese
# Get key at https://gradium.ai
GRADIUM_API_KEY=REDACTED_GRADIUM_API_KEY
