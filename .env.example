# Required — get from https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Voice Pipeline — Deepgram STT (streaming transcription)
# Get key at https://console.deepgram.com
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Voice Pipeline — ElevenLabs TTS (high-quality voice synthesis)
# Get key at https://elevenlabs.io
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# Optional — tertiary fallback TTS/STT
GRADIUM_API_KEY=your_gradium_key_here

# Optional — override generative models
STORYBOOK_IMAGE_MODEL=gemini-2.5-flash-image
STORYBOOK_TEXT_MODEL=gemini-2.5-flash
MEMORY_STYLIZE_MODEL=gemini-2.5-flash-image
MEMORY_VIDEO_MODEL=veo-2.0-generate-001
